    "gitleaks",
    "zap",
    "sarif",
    "cli"
  ],
  "homepage": "https://github.com/kousthubha-sky/secsuite-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kousthubha-sky/secsuite-cli.git"
  },
